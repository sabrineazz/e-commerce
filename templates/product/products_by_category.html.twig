{% extends 'base.html.twig' %}
{% block title %}{{ category.name }} - Our Store{% endblock %}

{% block body %}

    <!-- Breadcrumb -->
    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_index') }}" class="text-decoration-none">Home</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('productbrowse_categories') }}" class="text-decoration-none">Categories</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">{{ category.name }}</li>
            </ol>
        </nav>
    </div>

    <!-- Jumbotron -->
    <div class="container my-4">
        <div class="p-5 mb-4 bg-primary bg-gradient text-white rounded-3">
            <div class="container-fluid py-3">
                <h1 class="display-4 fw-bold">{{ category.name }}</h1>
                <span class="badge bg-light text-dark fs-6">{{ products|length }} Products Available</span>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="container mb-5">
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <h3>Browse {{ category.name }}</h3>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
                <div class="col">
                    <div class="card h-100">
                        {% if product.image %}
                            <img src="{{ asset('uploads/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}" style="height: 200px; object-fit: cover;">
                        {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-image text-muted" viewBox="0 0 16 16">
                                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                                    <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/>
                                </svg>
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">{{ category.name }}</span>
                            <h5 class="card-title">{{ product.name }}</h5>
                            <p class="card-text fw-bold text-success">{{ product.price|number_format(2, ',', ' ') }} €</p>
                            {% if product.stock > 0 %}
                                <span class="badge bg-success mb-2">En stock</span>
                            {% else %}
                                <span class="badge bg-danger mb-2">Rupture</span>
                            {% endif %}
                            <br>
                            <a href="{{ path('productproduct_details', {slug: product.slug}) }}" class="btn btn-outline-primary mt-2">View Details</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-muted">Aucun produit dans cette catégorie.</p>
            {% endfor %}
        </div>
    </div>

{% endblock %}
